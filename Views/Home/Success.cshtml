@{
    ViewData["Title"] = "Başvuru Alındı";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill" style="font-size: 4rem; color: #f5af19;"></i>
            </div>
            <h1 class="fw-bold mb-3" style="font-size: 2.5rem;">Başvurunuz Alındı!</h1>
            <p class="lead text-white-50 mb-4">
                Başvurunuz başarıyla kaydedildi. Ekibimiz en kısa sürede sizinle iletişime geçecek.
            </p>
            <div class="casting-card p-4 mb-4">
                <p class="mb-2 fw-semibold">Sıradaki Adımlar:</p>
                <ul class="list-unstyled text-white-50 small mb-0">
                    <li class="mb-2"><i class="bi bi-1-circle me-2" style="color:#f5af19"></i>Ekibimiz sizi arayacak</li>
                    <li class="mb-2"><i class="bi bi-2-circle me-2" style="color:#f5af19"></i>Seçme tarihi belirlenecek</li>
                    <li class="mb-2"><i class="bi bi-3-circle me-2" style="color:#f5af19"></i>Yeteneklerinizi sergileme zamanı!</li>
                </ul>
            </div>
            <a href="/" class="btn btn-outline-light rounded-pill px-5">
                <i class="bi bi-house me-2"></i>Ana Sayfaya Dön
            </a>
        </div>
    </div>
</div>
