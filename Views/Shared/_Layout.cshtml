<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ekol Medya</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --bg-deep: #08080f;
            --bg-mid: #10081e;
            --accent-1: #FF6B9D;
            --accent-2: #C084FC;
            --accent-3: #F43F5E;
            --accent-4: #D946EF;
            --glow: rgba(192,132,252,0.3);
        }
        body {
            background: linear-gradient(160deg, var(--bg-deep) 0%, var(--bg-mid) 50%, var(--bg-deep) 100%);
            min-height: 100vh;
            color: #fff;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .navbar { background: rgba(8,8,15,0.92) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(192,132,252,0.1) !important; }
        .hero-section { padding: 60px 0 40px; }
        .hero-title {
            font-size: 2.8rem;
            font-weight: 900;
            line-height: 1.2;
            background: linear-gradient(135deg, #fff 40%, var(--accent-1) 70%, var(--accent-2) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,0.65); max-width: 600px; margin: 0 auto; }
        .casting-card {
            background: rgba(255,255,255,0.04);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        .casting-card .form-control {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            color: #fff;
            border-radius: 12px;
            padding: 14px 18px;
            transition: all 0.3s;
        }
        .casting-card .form-control:focus {
            background: rgba(255,255,255,0.1);
            border-color: var(--accent-2);
            box-shadow: 0 0 0 3px var(--glow);
            color: #fff;
        }
        .casting-card .form-control::placeholder { color: rgba(255,255,255,0.3); }
        .casting-card .form-label { color: rgba(255,255,255,0.85); font-weight: 600; }
        .btn-casting {
            background: linear-gradient(135deg, var(--accent-3), var(--accent-4));
            border: none;
            color: #fff;
            font-weight: 700;
            padding: 14px 20px;
            border-radius: 50px;
            font-size: 1.1rem;
            transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            position: relative;
            overflow: hidden;
        }
        .btn-casting:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 35px rgba(217,70,239,0.35);
            color: #fff;
        }
        .btn-casting:active { transform: translateY(0) scale(0.98); }
        .brand-text {
            font-size: 0.8rem;
            color: var(--accent-2);
            letter-spacing: 4px;
            text-transform: uppercase;
            opacity: 0.8;
        }
        .feature-icon {
            width: 50px; height: 50px;
            background: rgba(192,132,252,0.12);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; color: var(--accent-2);
            border: 1px solid rgba(192,132,252,0.15);
        }
        .check-label { color: rgba(255,255,255,0.7); }
        .footer-text { color: rgba(255,255,255,0.25); font-size: 0.8rem; }
        .text-gradient { background: linear-gradient(135deg, var(--accent-1), var(--accent-2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .validation-summary-errors ul { margin: 0; padding: 0; list-style: none; }
        .validation-summary-errors { color: var(--accent-1); }
        .field-validation-error { color: var(--accent-1); }
        ::selection { background: rgba(192,132,252,0.3); color: #fff; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm border-bottom border-light border-opacity-10">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-camera-reels me-2"></i>Ekol Medya
            </a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="text-center py-4 footer-text">
        <div class="container">
            &copy; 2026 Ekol Medya &mdash; Tüm hakları saklıdır.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
